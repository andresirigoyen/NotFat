# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/notfat_db?schema=public"

# Supabase Configuration
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Expo Configuration
EXPO_PUBLIC_API_URL="https://your-api.example.com"
EXPO_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
EXPO_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Environment
NODE_ENV="development"
ENVIRONMENT="development"

# Authentication
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret"

# Payment Providers
MERCADOPAGO_ACCESS_TOKEN="your-mercadopago-access-token"
MERCADOPAGO_CLIENT_ID="your-mercadopago-client-id"
MERCADOPAGO_CLIENT_SECRET="your-mercadopago-client-secret"
MERCADOPAGO_WEBHOOK_SECRET="your-mercadopago-webhook-secret"

# RevenueCat (iOS/Android Subscriptions)
REVENUECAT_API_KEY="your-revenuecat-api-key"
REVENUECAT_APPLE_API_KEY="your-revenuecat-apple-api-key"
REVENUECAT_GOOGLE_API_KEY="your-revenuecat-google-api-key"

# External APIs
OPENAI_API_KEY="your-openai-api-key"
GOOGLE_GEMINI_API_KEY="your-google-gemini-api-key"
OPEN_FOOD_FACTS_API_URL="https://world.openfoodfacts.org/api/v2"

# Image Storage
AWS_S3_BUCKET="your-s3-bucket-name"
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_REGION="us-east-1"
AWS_S3_URL="https://your-s3-bucket-name.s3.us-east-1.amazonaws.com"

# Notification Services
EXPO_PUSH_NOTIFICATIONS_KEY="your-expo-push-notifications-key"
FCM_SERVER_KEY="your-firebase-cloud-messaging-server-key"

# Analytics
AMPLITUDE_API_KEY="your-amplitude-api-key"
MIXPANEL_TOKEN="your-mixpanel-token"
ANALYTICS_ENABLED="true"

# Email Services
SENDGRID_API_KEY="your-sendgrid-api-key"
EMAIL_FROM="noreply@notfat.app"
SUPPORT_EMAIL="support@notfat.app"

# Rate Limiting
REDIS_URL="redis://localhost:6379"
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"

# Security
CORS_ORIGIN="http://localhost:3000,https://yourapp.com"
JWT_SECRET="your-jwt-secret"
ENCRYPTION_KEY="your-encryption-key"

# Monitoring
SENTRY_DSN="your-sentry-dsn"
LOG_LEVEL="info"

# Development
DEBUG="notfat:*"
PORT="3000"

# Testing
TEST_DATABASE_URL="postgresql://username:password@localhost:5432/notfat_test_db?schema=public"
JEST_TIMEOUT="30000"

# Feature Flags
ENABLE_AI_FEATURES="true"
ENABLE_PAYMENT_FEATURES="true"
ENABLE_NOTIFICATIONS="true"
ENABLE_ANALYTICS="true"

# LLM Configuration
DEFAULT_LLM_MODEL="gemini-2.0-flash"
LLM_TIMEOUT_MS="30000"
LLM_MAX_RETRIES="3"

# Image Processing
IMAGE_MAX_SIZE_MB="10"
IMAGE_QUALITY="80"
SUPPORTED_IMAGE_FORMATS="jpg,jpeg,png,webp"

# Database Pool
DATABASE_POOL_MIN="2"
DATABASE_POOL_MAX="10"

# Cache Configuration
CACHE_TTL_SECONDS="3600"
CACHE_ENABLED="true"

# Webhook Configuration
WEBHOOK_SECRET="your-webhook-secret"
WEBHOOK_TIMEOUT_MS="5000"
