// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum gender_enum {
  male
  female
  non_binary
  other
}

enum user_role {
  user
  creator
  admin
  superadmin
}

enum height_unit_enum {
  cm
  m
  in
}

enum weight_unit_enum {
  kg
  lb
}

enum water_unit_enum {
  ml
  oz
}

enum unit_enum {
  g
  ml
  oz
  cup
  slice
  unit
  tbsp
  tsp
  scoop
  clove
}

enum meal_type_enum {
  breakfast
  lunch
  dinner
  snack
}

enum meal_status {
  analyzing
  complete
  error
  no_nutritional_info
  not_found
  contributed
  pending_lookup
  queued
}

enum meal_source_type_enum {
  camera
  gallery
  text
  scanner
  unknown
  voice
}

enum notification_type {
  simple_reminder
}

enum contribution_status {
  pending
  processing
  completed
  error
}

enum llm_model_enum {
  gemini_2_0_flash @map("gemini-2.0-flash")
  gpt_4_1_mini     @map("gpt-4.1-mini")
  open_food_facts  @map("open-food-facts")
  gemini_2_5_flash @map("gemini-2.5-flash")
  gpt_4_1          @map("gpt-4.1")
  gemini_2_5_pro   @map("gemini-2.5-pro")
}

enum task_type {
  image
  text
  voice
  barcode
}

enum body_fat_unit_enum {
  pct
}

enum nutrition_goal_source {
  algorithm
  ia
  manual
}

// Core Tables
model profiles {
  id                    String           @id @default(uuid())
  created_at            DateTime         @default(now())
  updated_at            DateTime         @updatedAt
  first_name            String?
  avatar_url            String?
  diet_type             String?          @default("Balanced")
  last_name             String?
  birth_date            DateTime?
  gender                gender_enum      @default(other)
  email                 String
  onboarding_completed  Boolean?
  workout_frequency     String?
  height_value          Float?
  weight_value          Float?
  height_unit           height_unit_enum @default(cm)
  weight_unit           weight_unit_enum @default(kg)
  timezone              String?          @default("")
  nutrition_goal        String?          @db.VarChar(255)
  achievement_goal      String?          @db.VarChar(255)
  subscription_status   String?          @default("free")
  subscription_ends_at  DateTime?
  expo_push_token       String?
  platform              String?          @default("ios")
  preferred_bottle_size Int              @default(1000)
  preferred_bottle_unit water_unit_enum  @default(ml)
  show_calories         Boolean          @default(true)
  show_hydration        Boolean          @default(true)
  onboarding_step       String?
  role                  user_role        @default(user)
  steps_goal            Int              @default(10000)

  // Relations
  meals                              meals[]
  food_items                         food_items[]
  water_logs                         water_logs[]
  body_metrics                       body_metrics[]
  subscriptions                      subscriptions[]
  payments                           payments[]
  notification_logs                  notification_logs[]
  notification_preferences           notification_preferences[]
  favorite_meals                     favorite_meals[]
  nutrition_goals                    nutrition_goals[]
  hydration_goals                    hydration_goals[]
  user_sports                        user_sports[]
  health_settings                    health_settings[]
  health_daily_snapshots             health_daily_snapshots[]
  user_activity_profile              user_activity_profile[]
  nutrition_guidelines               nutrition_guidelines[]
  profile_nutritionists              profile_nutritionists[]
  manual_workouts                    manual_workouts[]
  scan_events                        scan_events[]
  task_queue                         task_queue[]
  contribution_queue                 contribution_queue[]
  recipes                            recipes[]
  recipe_items                       recipe_items[]
  recommendation_sessions            recommendation_sessions[]
  coach_messages                     coach_messages[]
  coach_insights                     coach_insights[]
  daily_tips_used                    daily_tips_used[]
  pricing_ab_tests                   pricing_ab_tests[]
  offer_code_attempts                offer_code_attempts[]
  promo_codes_created                promo_codes[]
  payments_analytics                 payments_analytics[]
  cancellation_recovery_attempts     cancellation_recovery_attempts[]
  cancellation_with_plan             cancellation_with_plan[]
  cancellation_with_plan_and_payment cancellation_with_plan_and_payment[]
  feedback                           feedback[]
  influencers                        influencers[]
  institutions_created               institutions[]
  nutritionists                      nutritionists[]
  additives                          additives[]
  cron_job_logs                      cron_job_logs[]
  marketing_campaign_history         marketing_campaign_history[]
  daily_tips                         daily_tips[]

  @@map("profiles")
}

model meals {
  id                 String                @id @default(uuid())
  created_at         DateTime              @default(now())
  updated_at         DateTime              @updatedAt
  name               String?
  image_url          String?
  meal_type          meal_type_enum?
  meal_at            DateTime              @default(now())
  status             meal_status           @default(analyzing)
  source_type        meal_source_type_enum @default(unknown)
  recorded_timezone  String?
  llm_used           llm_model_enum?
  modified           Boolean               @default(false)
  is_from_favorite   Boolean               @default(false)
  image_url_aux      String?
  feedback           String?
  recommendation     String?
  api_time_ms        Int?
  processing_time_ms Int?
  prompt_version     String?

  // Relations
  user_id            String               @map("user_id")
  user               profiles             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  food_items         food_items[]
  scan_events        scan_events[]
  task_queue         task_queue[]
  contribution_queue contribution_queue[]
  favorite_meals     favorite_meals[]

  @@map("meals")
}

model food_items {
  id                     String     @id @default(uuid())
  created_at             DateTime   @default(now())
  updated_at             DateTime   @updatedAt
  name                   String
  quantity               Float?     @default(1)
  unit                   unit_enum?
  calories               Float?
  protein                Float?
  carbs                  Float?
  fat                    Float?
  barcode_number         String?
  scanned                Boolean    @default(false)
  servings               Float?
  contributed            Boolean    @default(false)
  nutriscore_grade       String?
  nova_group             Int?
  nutria_score           Int?
  labels_tags            Json?
  additives_tags         Json?
  nutria_score_breakdown Json?
  additives_details      Json?
  is_alcoholic           Boolean    @default(false)
  has_ingredients_data   Boolean?

  // Relations
  meal_id            String               @map("meal_id")
  meal               meals                @relation(fields: [meal_id], references: [id], onDelete: Cascade)
  profiles           profiles?            @relation(fields: [profilesId], references: [id])
  profilesId         String?
  contribution_queue contribution_queue[]

  @@map("food_items")
}

model water_logs {
  id                String          @id @default(uuid())
  logged_at         DateTime
  recorded_timezone String?
  volume            Float
  unit              water_unit_enum @default(ml)
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt

  // Relations
  user_id String   @map("user_id")
  user    profiles @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("water_logs")
}

model body_metrics {
  id             String             @id @default(uuid())
  measured_at    DateTime           @default(now())
  weight_value   Float?
  body_fat_value Float?
  height_value   Float?
  weight_unit    weight_unit_enum   @default(kg)
  height_unit    height_unit_enum   @default(cm)
  body_fat_unit  body_fat_unit_enum @default(pct)

  // Relations
  user_id String   @map("user_id")
  user    profiles @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("body_metrics")
}

model subscriptions {
  id                       String    @id @default(uuid())
  user_id                  String?   @map("user_id")
  mercadopago_id           String?
  plan_type                String
  status                   String    @default("pending")
  amount                   Float?
  currency                 String    @default("CLP")
  start_date               DateTime?
  trial_end_date           DateTime?
  end_date                 DateTime?
  created_at               DateTime  @default(now())
  updated_at               DateTime  @updatedAt
  payment_provider         String    @default("mercadopago")
  provider_subscription_id String?
  revenuecat_id            String?
  environment              String?
  offer_code               String?
  applied_offer_code       String?   @db.VarChar(50)

  // Relations
  user                               profiles?                            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  payments                           payments[]
  promo_code_payments                promo_code_payments[]
  offer_code_attempts                offer_code_attempts[]
  cancellation_with_plan             cancellation_with_plan[]
  cancellation_with_plan_and_payment cancellation_with_plan_and_payment[]
  cancellation_recovery_attempts     cancellation_recovery_attempts[]

  @@map("subscriptions")
}

model payments {
  id                     String   @id @default(uuid())
  user_id                String   @map("user_id")
  subscription_id        String?  @map("subscription_id")
  mercadopago_payment_id String?
  status                 String
  status_detail          String?
  payment_type           String?
  amount                 Float
  currency               String
  payment_date           DateTime
  last_modified          DateTime
  payment_data           Json?
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt
  operation_type         String?
  revenuecat_payment_id  String?
  environment            String?

  // Relations
  user         profiles       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  subscription subscriptions? @relation(fields: [subscription_id], references: [id], onDelete: SetNull)

  @@map("payments")
}

model notification_logs {
  id                String            @id @default(uuid())
  sent_at           DateTime          @default(now())
  notification_type notification_type
  reminder_id       String?           @map("reminder_id")

  // Relations
  user_id  String                    @map("user_id")
  user     profiles                  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  reminder notification_preferences? @relation(fields: [reminder_id], references: [id], onDelete: SetNull)

  @@map("notification_logs")
}

model notification_preferences {
  id              String          @id @default(uuid())
  hour            Int
  minute          Int
  meal_type       meal_type_enum?
  enabled         Boolean         @default(true)
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt
  is_custom       Boolean         @default(false)
  label           String?
  message         String?
  icon            String?
  predefined_type String?

  // Relations
  user_id           String              @map("user_id")
  user              profiles            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  notification_logs notification_logs[]

  @@map("notification_preferences")
}

model favorite_meals {
  id               String                @id @default(uuid())
  created_at       DateTime              @default(now())
  updated_at       DateTime              @updatedAt
  name             String?
  image_url        String?
  meal_type        meal_type_enum?
  source_type      meal_source_type_enum @default(unknown)
  original_meal_id String?

  // Relations
  user_id             String                @map("user_id")
  user                profiles              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  meals               meals?                @relation(fields: [original_meal_id], references: [id], onDelete: SetNull)
  favorite_meal_items favorite_meal_items[]

  @@map("favorite_meals")
}

model favorite_meal_items {
  id             String     @id @default(uuid())
  created_at     DateTime   @default(now())
  name           String
  quantity       Float?     @default(1)
  unit           unit_enum?
  calories       Float?
  protein        Float?
  carbs          Float?
  fat            Float?
  servings       Float?
  barcode_number String?
  scanned        Boolean    @default(false)
  contributed    Boolean    @default(false)

  // Relations
  favorite_meal_id String         @map("favorite_meal_id")
  favorite_meal    favorite_meals @relation(fields: [favorite_meal_id], references: [id], onDelete: Cascade)

  @@map("favorite_meal_items")
}

model nutrition_goals {
  id         String                 @id @default(uuid())
  calories   Int?
  protein    Int?
  carbs      Int?
  fat        Int?
  start_date DateTime               @default(now())
  end_date   DateTime?
  created_at DateTime               @default(now())
  updated_at DateTime               @updatedAt
  source     nutrition_goal_source?

  // Relations
  user_id String   @map("user_id")
  user    profiles @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("nutrition_goals")
}

model hydration_goals {
  id          String          @id @default(uuid())
  target      Float
  target_unit water_unit_enum @default(ml)
  start_date  DateTime
  end_date    DateTime?
  created_at  DateTime        @default(now())
  updated_at  DateTime        @updatedAt

  // Relations
  user_id String   @map("user_id")
  user    profiles @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("hydration_goals")
}

model user_sports {
  id             String   @id @default(uuid())
  sport_type     String
  hours_per_week Float?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  // Relations
  user_id String   @map("user_id")
  user    profiles @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_sports")
}

model health_settings {
  id                         String    @id @default(uuid())
  health_platform            String?
  connected_at               DateTime?
  disconnected_at            DateTime?
  eat_back_exercise_calories Boolean   @default(true)
  eat_back_neat_calories     Boolean   @default(true)
  sync_weight                Boolean   @default(true)
  created_at                 DateTime  @default(now())
  updated_at                 DateTime  @updatedAt

  // Relations
  user_id String   @map("user_id")
  user    profiles @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("health_settings")
}

model health_daily_snapshots {
  id                      String   @id @default(uuid())
  date                    DateTime @db.Date
  steps                   Int?
  active_calories_burned  Float?
  workout_calories_burned Float?
  workout_count           Int?
  workout_minutes         Int?
  weight_kg               Float?
  sleep_hours             Float?
  sleep_quality           String?
  synced_at               DateTime @default(now())
  source                  String?  @default("apple_health")

  // Relations
  user_id String   @map("user_id")
  user    profiles @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("health_daily_snapshots")
}

model user_activity_profile {
  id                      String    @id @default(uuid())
  does_sport              Boolean?
  daily_activity_level    String?
  activity_system_version String    @default("v2")
  upgraded_to_v2_at       DateTime?
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  // Relations
  user_id String   @map("user_id")
  user    profiles @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_activity_profile")
}

model nutrition_guidelines {
  id              String   @id @default(uuid())
  user_id         String?  @map("user_id")
  nutritionist_id String?  @map("nutritionist_id")
  name            String
  status          String   @default("draft")
  allergies       String[]
  pathologies     String[]
  food_aversions  String[]
  cooking_time    String?
  supplementation Boolean  @default(false)
  notes           String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // Relations
  user                  profiles?               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  nutritionist          nutritionists?          @relation(fields: [nutritionist_id], references: [id], onDelete: SetNull)
  guideline_days        guideline_days[]
  profile_nutritionists profile_nutritionists[]

  @@map("nutrition_guidelines")
}

model profile_nutritionists {
  id         String   @id @default(uuid())
  created_at DateTime @default(now())

  // Relations
  profile_id             String                @map("profile_id")
  profile                profiles              @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  nutritionist_id        String                @map("nutritionist_id")
  nutritionist           nutritionists         @relation(fields: [nutritionist_id], references: [id], onDelete: Cascade)
  nutrition_guidelines   nutrition_guidelines? @relation(fields: [nutrition_guidelinesId], references: [id])
  nutrition_guidelinesId String?

  @@map("profile_nutritionists")
}

model manual_workouts {
  id                 String   @id @default(uuid())
  workout_date       DateTime @db.Date
  sport_type         String
  duration_minutes   Int
  estimated_calories Int
  created_at         DateTime @default(now())

  // Relations
  user_id String   @map("user_id")
  user    profiles @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("manual_workouts")
}

model scan_events {
  id            String    @id @default(uuid())
  barcode       String
  origin        String
  result        String?
  product_name  String?
  processing_ms Int?
  created_at    DateTime  @default(now())
  completed_at  DateTime?

  // Relations
  user_id String   @map("user_id")
  user    profiles @relation(fields: [user_id], references: [id], onDelete: Cascade)
  meal_id String?  @map("meal_id")
  meal    meals?   @relation(fields: [meal_id], references: [id], onDelete: SetNull)

  @@map("scan_events")
}

model task_queue {
  id                      String    @id @default(uuid())
  image_url               String?
  text_description        String?
  audio_url               String?
  barcode                 String?
  retry_count             Int       @default(0)
  max_retries             Int       @default(3)
  error_message           String?
  last_error_at           DateTime?
  processing_started_at   DateTime?
  processing_completed_at DateTime?
  metadata                Json?
  photo_comment           String?
  task_type               task_type
  status                  String    @default("pending")
  priority                Int       @default(5)
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  // Relations
  meal_id    String    @map("meal_id")
  meal       meals     @relation(fields: [meal_id], references: [id], onDelete: Cascade)
  profiles   profiles? @relation(fields: [profilesId], references: [id])
  profilesId String?

  @@map("task_queue")
}

model contribution_queue {
  id                      String              @id @default(uuid())
  user_id                 String?
  barcode                 String?
  front_image_url         String?
  nutrition_image_url     String?
  extra_image_url         String?
  retry_count             Int                 @default(0)
  max_retries             Int                 @default(3)
  processing_started_at   DateTime?
  processing_completed_at DateTime?
  error_message           String?
  last_error_at           DateTime?
  result_data             Json?
  metadata                Json?
  updated_at              DateTime?
  status                  contribution_status @default(pending)
  priority                Int                 @default(5)
  created_at              DateTime            @default(now())

  // Relations
  meal_id      String?     @map("meal_id")
  meal         meals?      @relation(fields: [meal_id], references: [id], onDelete: SetNull)
  food_item_id String?     @map("food_item_id")
  food_item    food_items? @relation(fields: [food_item_id], references: [id], onDelete: SetNull)
  profiles     profiles?   @relation(fields: [profilesId], references: [id])
  profilesId   String?

  @@map("contribution_queue")
}

model recipes {
  id                        String          @id @default(uuid())
  created_at                DateTime        @default(now())
  updated_at                DateTime        @updatedAt
  name                      String
  image_url                 String?
  meal_type                 meal_type_enum
  source                    String?         @default("ai_recommendation")
  description               String?
  estimated_time            String?
  difficulty                String?
  recipe_type               String?
  steps                     String[]
  llm_used                  llm_model_enum?
  api_time_ms               Int?
  processing_time_ms        Int?
  is_favorite               Boolean         @default(false)
  recommendation_session_id String?         @map("recommendation_session_id")

  // Relations
  user_id                String                   @map("user_id")
  user                   profiles                 @relation(fields: [user_id], references: [id], onDelete: Cascade)
  recipe_items           recipe_items[]
  recommendation_session recommendation_sessions? @relation(fields: [recommendation_session_id], references: [id], onDelete: SetNull)

  @@map("recipes")
}

model recipe_items {
  id             String     @id @default(uuid())
  created_at     DateTime   @default(now())
  name           String
  quantity       Float?     @default(1)
  unit           unit_enum?
  calories       Float?
  protein        Float?
  carbs          Float?
  fat            Float?
  updated_at     DateTime   @updatedAt
  barcode_number String?
  scanned        Boolean    @default(false)
  servings       Float?
  contributed    Boolean    @default(false)

  // Relations
  recipe_id  String    @map("recipe_id")
  recipe     recipes   @relation(fields: [recipe_id], references: [id], onDelete: Cascade)
  profiles   profiles? @relation(fields: [profilesId], references: [id])
  profilesId String?

  @@map("recipe_items")
}

model recommendation_sessions {
  id                    String          @id @default(uuid())
  meal_type             meal_type_enum
  available_ingredients String?
  remaining_calories    Float?
  remaining_protein     Float?
  remaining_carbs       Float?
  remaining_fat         Float?
  llm_used              llm_model_enum?
  api_time_ms           Int?
  total_time_ms         Int?
  fridge_image_url      String?
  created_at            DateTime        @default(now())
  updated_at            DateTime        @updatedAt

  // Relations
  user_id String    @map("user_id")
  user    profiles  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  recipes recipes[]

  @@map("recommendation_sessions")
}

model coach_messages {
  id         String   @id @default(uuid())
  role       String
  content    String
  audio_url  String?
  metadata   Json?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  user_id String   @map("user_id")
  user    profiles @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("coach_messages")
}

model coach_insights {
  id           String   @id @default(uuid())
  insights     Json
  generated_at DateTime @default(now())
  expires_at   DateTime @default(dbgenerated("(now() + '04:00:00'::interval)"))
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  // Relations
  user_id String   @map("user_id")
  user    profiles @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("coach_insights")
}

model daily_tips {
  id          Int       @id @default(autoincrement())
  emoji       String    @default("💡")
  category    String    @default("nutrición")
  title       String
  description String
  used_at     DateTime? @db.Date
  created_at  DateTime  @default(now())

  // Relations
  daily_tips_used daily_tips_used[]
  profiles        profiles?         @relation(fields: [profilesId], references: [id])
  profilesId      String?

  @@map("daily_tips")
}

// Support tables for daily_tips relationship
model daily_tips_used {
  id      String   @id @default(uuid())
  used_at DateTime @default(now())

  // Relations
  user_id String     @map("user_id")
  user    profiles   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tip_id  Int        @map("tip_id")
  tip     daily_tips @relation(fields: [tip_id], references: [id], onDelete: Cascade)

  @@unique([user_id, tip_id])
  @@map("daily_tips_used")
}

model pricing_ab_tests {
  id           Int       @id @default(autoincrement())
  test_group   String
  price_shown  Int
  converted    Boolean   @default(false)
  converted_at DateTime?
  created_at   DateTime  @default(now())

  // Relations
  user_id String   @map("user_id")
  user    profiles @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("pricing_ab_tests")
}

model offer_code_attempts {
  id         String    @id @default(uuid())
  offer_code String    @db.VarChar(50)
  used_at    DateTime?
