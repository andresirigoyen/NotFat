{
  "expo": {
    "name": "NotFat",
    "slug": "notfat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.notfat.app",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "NSCameraUsageDescription": "NotFat necesita acceso a la cámara para escanear alimentos y tomar fotos de tus comidas.",
        "NSPhotoLibraryUsageDescription": "NotFat necesita acceso a tu galería para que puedas seleccionar fotos de alimentos.",
        "NSMicrophoneUsageDescription": "NotFat necesita acceso al micrófono para comandos de voz y grabación de notas.",
        "NSHealthShareUsageDescription": "NotFat necesita acceso a tus datos de salud para sincronizar actividad, peso y otros métricas.",
        "NSHealthUpdateUsageDescription": "NotFat necesita permiso para actualizar tus datos de salud en la aplicación Salud.",
        "LSApplicationQueriesSchemes": [
          "instagram",
          "facebook",
          "twitter",
          "instagram",
          "facebook",
          "twitter"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.notfat.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": {
            "scheme": "notfat"
          },
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir a NotFat acceder a tu cámara"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir a NotFat acceder a tus fotos"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#22c55e",
          "sounds": [
            "./assets/sounds/notification.wav"
          ]
        }
      ],
      [
        "sentry-expo",
        {
          "url": "https://your-sentry-dsn@sentry.io/project-id",
          "organization": "notfat",
          "project": "notfat-mobile"
        }
      ],
      [
        "@sentry/react-native",
        {
          "url": "https://your-sentry-dsn@sentry.io/project-id"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-barcode-scanner",
      "expo-font"
    ],
    "scheme": "notfat",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "extra": {
      "eas": {
        "projectId": "553bccf5-0d45-4301-84a2-0ed34526a3a9"
      }
    },
    "owner": "thebeebaby"
  }
}
