{
  "compilerOptions": {
    "allowJs": true,
    "lib": ["ESNext", "DOM"],
    "module": "esnext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
